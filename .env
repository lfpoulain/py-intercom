# ============================================================
# py-intercom — Configuration (.env)
# ============================================================
# Ce fichier centralise les variables ajustables.
# Il n'est PAS lu automatiquement par l'app (les valeurs sont
# dans common/constants.py et les arguments CLI).
# Il sert de référence pour personnaliser un déploiement.
# ============================================================

# --- Audio ---
SAMPLE_RATE=48000
CHANNELS=1
FRAME_SAMPLES=480

# --- Opus codec ---
OPUS_BITRATE=64000
OPUS_COMPLEXITY=5

# --- Réseau ---
AUDIO_UDP_PORT=5000
CONTROL_PORT_OFFSET=1
DISCOVERY_PORT_OFFSET=2
MAX_UDP_PAYLOAD_BYTES=1200
PACKET_HEADER_BYTES=12

# --- Discovery ---
DISCOVERY_BEACON_INTERVAL_S=2.0
DISCOVERY_EXPIRY_S=6.0

# --- Serveur ---
SERVER_BIND_IP=0.0.0.0
SERVER_NAME=py-intercom

# --- Client web ---
WEB_HOST=0.0.0.0
WEB_PORT=8443
WEB_SSL_ADHOC=true
# WEB_SSL_CERT=
# WEB_SSL_KEY=

# --- Presets (chemins par défaut : ~/py-intercom/) ---
# SERVER_PRESET_PATH=
# CLIENT_PRESET_PATH=

# --- Debug ---
DEBUG=false
